# Portal de Acceso CFOTech — variables de entorno Vite
# ──────────────────────────────────────────────────────
# Copiar este archivo a .env y ajustar los valores al entorno.
# En desarrollo local dejar todo como está (localhost).
# En producción/red interna cambiar VITE_HOST a la IP o hostname del servidor.

# Host donde corren el portal y las apps (sin puerto, sin protocolo)
# Ej. local: localhost
# Ej. red:   192.168.1.100
# Ej. dominio: portal.cfotechlatam.com
VITE_HOST=localhost

# Puerto del portal shell (Vite)
VITE_PORTAL_PORT=5174

# Puerto del Portal Launcher (Flask)
VITE_LAUNCHER_PORT=4999
