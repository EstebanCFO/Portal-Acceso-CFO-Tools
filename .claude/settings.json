{
  "env": {
    "PONYTAIL_DEFAULT_MODE": "ultra"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/pre-commit-tests.sh\"",
            "if": "Bash(git commit *)",
            "timeout": 120,
            "statusMessage": "🧪 Verificando tests antes de commitear..."
          }
        ]
      }
    ]
  }
}
